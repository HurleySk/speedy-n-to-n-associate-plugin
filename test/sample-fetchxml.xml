<!--
  Sample FetchXML for Speedy N:N Associate plugin.
  Targets the test entities created by create-test-data.ps1.
  Returns all testwidget IDs paired with all testgadget IDs via cross-join.
  Adjust the filter conditions to limit the result set.
-->
<fetch count="5000">
  <entity name="spdy_testwidget">
    <attribute name="spdy_testwidgetid" />
    <link-entity name="spdy_testgadget" from="spdy_testgadgetid" to="spdy_testwidgetid" link-type="outer">
      <attribute name="spdy_testgadgetid" alias="gadgetid" />
    </link-entity>
  </entity>
</fetch>
